@page
@model PythonStudy.Pages.SandboxModel
@{
}

<h5 style="margin: auto; width: 200px;">Online C++ compiler</h5>

<div style="width: 900px; height: 540px; margin: 20px auto; position: relative;">
    <div id="editor" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; font-size: 20px; width: 100%; height: 100%;">

    </div>
</div>
    
<script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.14.0/ace.js"></script>
<script type="text/javascript" charset="utf-8">
let editor = document.querySelector("#editor");
    
ace.edit(editor, {
    theme: 'ace/theme/cobalt',
    mode: 'ace/mode/c_cpp'
})
</script>